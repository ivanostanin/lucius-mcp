      "registryType": "pypi",
      "identifier": "lucius-mcp",
      "version": "0.8.3",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ALLURE_ENDPOINT",
          "description": "Allure TestOps base URL, for example https://example.testops.cloud.",
