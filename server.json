  "name": "io.github.ivanostanin/lucius-mcp",
  "title": "Lucius MCP",
  "description": "MCP server for managing Allure TestOps tests, launches, plans, defects, and metadata.",
  "repository": {
    "url": "https://github.com/ivanostanin/lucius-mcp",
    "source": "github"
  },
  "version": "0.13.0",
